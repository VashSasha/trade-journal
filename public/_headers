# Never cache the HTML entry point, so every visitor always gets an
# index.html that references the current (hashed) JS/CSS chunk names.
# Prevents "Failed to load module script ... MIME type text/html" after
# a new deploy, where a cached index.html points at chunk hashes that
# no longer exist.
/index.html
  Cache-Control: no-cache
/
  Cache-Control: no-cache

# Hashed build assets are content-addressed (name changes when content
# changes), so they're safe to cache forever.
/*.js
  Cache-Control: public, max-age=31536000, immutable
/*.css
  Cache-Control: public, max-age=31536000, immutable
